# BankSec Enterprise Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Secret key for Flask sessions and JWT tokens
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-change-me-immediately
JWT_SECRET_KEY=your-jwt-secret-key-here-change-me-immediately

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://banksec:banksec_password@localhost:5432/banksec_enterprise

# Alternative: Use PgBouncer for connection pooling
# DATABASE_URL=postgresql://banksec:banksec_password@localhost:6432/banksec_enterprise

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis connection URL for caching and sessions
REDIS_URL=redis://localhost:6379/0

# Redis configuration for Celery (can be same as above)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment: development, testing, staging, production
FLASK_ENV=development

# Debug mode (only for development)
FLASK_DEBUG=True

# Application port
PORT=5000

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
# LOG_FILE=/var/log/banksec/app.log

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true

# Metrics port
METRICS_PORT=9090

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================

# Redis storage for rate limiting (can be same as main Redis)
RATELIMIT_STORAGE_URL=redis://localhost:6379/0

# Default rate limits
# Format: "requests per time_period"
RATELIMIT_DEFAULT=200 per day, 50 per hour, 10 per minute

# =============================================================================
# JWT CONFIGURATION
# =============================================================================

# JWT access token expiration (seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600

# JWT refresh token expiration (seconds)
JWT_REFRESH_TOKEN_EXPIRES=2592000

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================

# Session timeout (seconds)
SESSION_TIMEOUT=3600

# Maximum simultaneous sessions per user
MAX_SIMULTANEOUS_SESSIONS=3

# =============================================================================
# SIMULATION CONFIGURATION
# =============================================================================

# Simulation timeout (seconds)
SIMULATION_TIMEOUT=300

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Maximum login attempts
MAX_LOGIN_ATTEMPTS=5

# Password reset timeout (seconds)
PASSWORD_RESET_TIMEOUT=3600

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# SMTP server for email notifications
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# New Relic license key
# NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================

# Override database for development
# DEV_DATABASE_URL=sqlite:///banksec_dev.db

# Override Redis for development
# DEV_REDIS_URL=redis://localhost:6379/1

# =============================================================================
# PRODUCTION WARNINGS
# =============================================================================

# NEVER use the default values in production!
# ALWAYS set strong, unique passwords and keys!
# ALWAYS use HTTPS in production!
# ALWAYS enable security headers!
# ALWAYS monitor your application!